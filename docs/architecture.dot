// amplifierd Architecture — Tool Execution Pipeline & Blocking Analysis
//
// Color semantics:
//   RED    (#FFCDD2 fill / #F44336 border) = BLOCKING  — synchronous call on event loop
//   GREEN  (#C8E6C9 fill / #388E3C border) = OFFLOADED — asyncio.to_thread / properly async
//   BLUE   (#BBDEFB fill / #1565C0 border) = ASYNC-SAFE — non-blocking, coroutine-based
//   ORANGE (#FFE0B2 fill / #E65100 border) = EVENT LOOP — runs on main asyncio thread
//   PURPLE (#D1C4E9 fill / #4527A0 border) = EXTERNAL  — amplifier_core library
//   GRAY   (#F5F5F5 fill)                  = NEUTRAL   — infrastructure / config
//
// Render: dot -Tsvg architecture.dot -o architecture.svg
//         dot -Tpng architecture.dot -o architecture.png

digraph amplifierd_architecture {

    // ── Graph-level attributes ───────────────────────────────────────────────
    label     = "amplifierd Architecture — Tool Execution Pipeline & Blocking Analysis"
    labelloc  = t
    labeljust = c
    rankdir   = LR
    compound  = true
    fontname  = "Helvetica"
    fontsize  = 15
    nodesep   = 0.55
    ranksep   = 1.3
    pad       = 0.6

    node [fontname="Helvetica" fontsize=10 style="rounded,filled"
          fillcolor="#F5F5F5" color="#9E9E9E" margin="0.18,0.12"]
    edge [fontname="Helvetica" fontsize=9 color="#555555" arrowsize=0.8]


    // ════════════════════════════════════════════════════════════════════════
    // CLUSTER: Entry / Startup
    // ════════════════════════════════════════════════════════════════════════
    subgraph cluster_entry {
        label     = "Entry Flow  (startup)"
        style     = filled
        fillcolor = "#FAFAFA"
        color     = "#BDBDBD"
        fontname  = "Helvetica"
        fontsize  = 11

        cli [label="cli.py" shape=box]
        uvicorn [label="uvicorn.run()" shape=box]
        app [label="app.py\ncreate_app()" shape=box
             fillcolor="#FFE0B2" color="#E65100"]
        lifespan [label="_lifespan()  startup\n· load keys.env\n· BundleRegistry\n· SessionManager init\n· discover_plugins\n· asyncio.create_task(prewarm)"
                  shape=box fillcolor="#FFE0B2" color="#E65100"]

        cli -> uvicorn [label="starts"]
        uvicorn -> app [label="calls"]
        app -> lifespan [label="@asynccontextmanager\nstartup hook"]
    }


    // ════════════════════════════════════════════════════════════════════════
    // CLUSTER: HTTP Routes
    // ════════════════════════════════════════════════════════════════════════
    subgraph cluster_routes {
        label     = "HTTP Routes  (routes/)"
        style     = filled
        fillcolor = "#E3F2FD"
        color     = "#1565C0"
        fontname  = "Helvetica"
        fontsize  = 11

        route_execute [label="POST /sessions/{id}/execute\n(synchronous — awaits result)"
                       shape=box fillcolor="#BBDEFB" color="#1565C0"]
        route_stream  [label="POST /sessions/{id}/execute/stream\n\xe2\x86\x92 202 Accepted  (primary path)"
                       shape=box fillcolor="#BBDEFB" color="#1565C0" penwidth=2]
        route_events  [label="GET /events\nSSE  StreamingResponse"
                       shape=box fillcolor="#BBDEFB" color="#1565C0"]
        route_agents  [label="POST /agents\nspawn / resume child sessions"
                       shape=box fillcolor="#BBDEFB" color="#1565C0"]
        route_approvals [label="POST /approvals\nPendingApproval + asyncio.Future gate"
                         shape=box fillcolor="#BBDEFB" color="#1565C0"]
        route_health  [label="GET /health,  GET /ready\nprewarm gate"
                       shape=box fillcolor="#BBDEFB" color="#1565C0"]

        // Layout ordering (invisible spine)
        route_execute   -> route_stream    [style=invis]
        route_stream    -> route_events    [style=invis]
        route_events    -> route_agents    [style=invis]
        route_agents    -> route_approvals [style=invis]
        route_approvals -> route_health    [style=invis]
    }


    // ════════════════════════════════════════════════════════════════════════
    // CLUSTER: State Layer
    // ════════════════════════════════════════════════════════════════════════
    subgraph cluster_state {
        label     = "State Layer  (state/)"
        style     = filled
        fillcolor = "#FFF8E1"
        color     = "#F57F17"
        fontname  = "Helvetica"
        fontsize  = 11

        session_manager [label="SessionManager\n· creates / registers / resumes / destroys\n· owns _sessions dict\n· owns _prepared_bundles cache\n· central authority"
                         shape=box fillcolor="#FFE0B2" color="#E65100"]

        session_handle  [label="SessionHandle\n· execute() sets status IDLE \xe2\x86\x92 EXECUTING\n· await self._session.execute(prompt)\n· _wire_events() hooks kernel \xe2\x86\x92 EventBus"
                         shape=box fillcolor="#FFE0B2" color="#E65100" penwidth=2]

        event_bus       [label="EventBus\n· publish(session_id, name, data)  [sync]\n· subscribe()  async generator\n· queue.put_nowait() per subscriber\n· 15s keepalive  · session-tree aware"
                         shape=box fillcolor="#BBDEFB" color="#1565C0"]

        session_index   [label="SessionIndex\nflat JSON registry  (persistent)\nsave()  \xe2\x86\x90 SYNC DISK WRITE"
                         shape=cylinder fillcolor="#FFCDD2" color="#F44336" penwidth=2]

        transport_event [label="TransportEvent\n__slots__ optimized\nevent envelope"
                         shape=note fillcolor="#F5F5F5" color="#9E9E9E"]
    }


    // ════════════════════════════════════════════════════════════════════════
    // BACKGROUND TASK node (bridges routes -> state)
    // ════════════════════════════════════════════════════════════════════════
    bg_task [label="asyncio.create_task(_run())\n\xe2\x9a\xa0  ENTIRE TASK RUNS ON EVENT LOOP THREAD"
             shape=parallelogram fillcolor="#FFE0B2" color="#E65100" penwidth=2 fontsize=10]


    // ════════════════════════════════════════════════════════════════════════
    // CLUSTER: amplifier_core  (external library)
    // ════════════════════════════════════════════════════════════════════════
    subgraph cluster_core {
        label     = "amplifier_core  (external library)"
        style     = filled
        fillcolor = "#EDE7F6"
        color     = "#4527A0"
        fontname  = "Helvetica"
        fontsize  = 11

        ampl_session [label="AmplifierSession\nkernel session object"
                      shape=box fillcolor="#D1C4E9" color="#4527A0"]

        coordinator  [label="Coordinator\nhooks \xc2\xb7 events \xc2\xb7 capabilities\nhooks.emit(\"tool:pre\")  \xe2\x86\x92  handlers\nhooks.emit(\"tool:post\")  \xe2\x86\x92  handlers\nhooks.emit(\"orchestrator:complete\")"
                      shape=box fillcolor="#D1C4E9" color="#4527A0"]

        orchestrator [label="Orchestrator  \xe2\x80\x94 main engine loop\n\xe2\x91\xa0 context.add_message(user prompt)\n\xe2\x91\xa1 await provider.complete(messages)\n\xe2\x91\xa2 for each tool_call in response:\n       hooks.emit(\"tool:pre\")\n       tool.execute(args)    \xe2\x86\x90  \xe2\x9a\xa0  HERE\n       hooks.emit(\"tool:post\")\n\xe2\x91\xa3 hooks.emit(\"orchestrator:complete\")"
                      shape=box fillcolor="#FFE0B2" color="#E65100" penwidth=2]

        provider     [label="Provider\nLLM backend API\nawait provider.complete(messages)\nasync / non-blocking  \xe2\x9c\x93"
                      shape=box fillcolor="#C8E6C9" color="#388E3C"]

        // ── THE CRITICAL BLOCKING CALL ────────────────────────────────────
        tool_execute [label="\xe2\x9a\xa0  tool.execute(args)\n\nSYNCHRONOUS \xe2\x80\x94 no await, no thread\nRuns directly on event loop thread\n\nExamples that block:\n  bash tool   \xe2\x86\x92 subprocess.run()\n  glob tool   \xe2\x86\x92 disk directory scan\n  grep tool   \xe2\x86\x92 disk read + regex\n  read_file   \xe2\x86\x92 open() + read()"
                      shape=box style="filled"
                      fillcolor="#F44336" fontcolor="white"
                      color="#B71C1C" penwidth=4 fontsize=11]
    }


    // ════════════════════════════════════════════════════════════════════════
    // BLOCKING IMPACT annotation
    // ════════════════════════════════════════════════════════════════════════
    blocking_impact [label="\xe2\x9b\x94  EVENT LOOP FROZEN\n\nDuration: entire tool.execute() wall time\n\n\xc2\xb7 SSE events not delivered\n\xc2\xb7 Keepalive timer suspended\n\xc2\xb7 New HTTP requests not accepted\n\xc2\xb7 EventBus.subscribe() generator stalls\n\xc2\xb7 All active sessions affected\n\xc2\xb7 route_approvals gate unresponsive"
                     shape=note style=filled
                     fillcolor="#FFEBEE" color="#C62828" fontcolor="#C62828"
                     penwidth=2 fontsize=10]


    // ════════════════════════════════════════════════════════════════════════
    // CLUSTER: Support Layer
    // ════════════════════════════════════════════════════════════════════════
    subgraph cluster_support {
        label     = "Support Layer"
        style     = filled
        fillcolor = "#F1F8E9"
        color     = "#33691E"
        fontname  = "Helvetica"
        fontsize  = 11

        persistence [label="persistence.py\nTranscriptSaveHook\nMetadataSaveHook\nwrite_transcript() \xe2\x86\x92 asyncio.to_thread()  \xe2\x9c\x93\nwrite_metadata()  \xe2\x86\x92 asyncio.to_thread()  \xe2\x9c\x93"
                     shape=box fillcolor="#C8E6C9" color="#388E3C"]

        display [label="display.py\nEventBusDisplaySystem\ndisplay events \xe2\x86\x92 SSE fanout"
                 shape=box fillcolor="#BBDEFB" color="#1565C0"]

        spawn [label="spawn.py\nsession.spawn() capability\nchild session lifecycle\nEventBus parent/child tree wiring"
               shape=box fillcolor="#FFE0B2" color="#E65100"]

        providers_load [label="providers.py\nload_provider_config()\nsync YAML read  \xe2\x86\x90 BLOCKING\ncalled on create and resume"
                        shape=box fillcolor="#FFCDD2" color="#F44336" penwidth=2]

        bundle_prepare [label="BundleRegistry\nbundle.prepare()\nasyncio.to_thread(lambda: asyncio.run(...))  \xe2\x9c\x93"
                        shape=box fillcolor="#C8E6C9" color="#388E3C"]

        plugins [label="plugins.py\nentry-point plugin discovery\ndiscover_plugins()" shape=box]

        daemon_config [label="config.py\nDaemonSettings\n(pydantic-settings)"
                       shape=note fillcolor="#F5F5F5" color="#9E9E9E"]
    }


    // ════════════════════════════════════════════════════════════════════════
    // SSE CLIENT (output endpoint — affected by blocking)
    // ════════════════════════════════════════════════════════════════════════
    sse_client [label="SSE Client\n\xe2\x9a\xa0  no events received\n    while tool.execute() runs"
                shape=parallelogram fillcolor="#FFCDD2" color="#F44336" fontsize=10]


    // ════════════════════════════════════════════════════════════════════════
    // LEGEND
    // ════════════════════════════════════════════════════════════════════════
    subgraph cluster_legend {
        label     = "Legend"
        style     = filled
        fillcolor = "#FAFAFA"
        color     = "#9E9E9E"
        fontname  = "Helvetica"
        fontsize  = 11

        l_block    [label="BLOCKING\nsync on event loop"       shape=box fillcolor="#FFCDD2" color="#F44336" penwidth=2]
        l_offload  [label="OFFLOADED\nasyncio.to_thread  \xe2\x9c\x93"  shape=box fillcolor="#C8E6C9" color="#388E3C"]
        l_async    [label="ASYNC-SAFE\nnon-blocking"            shape=box fillcolor="#BBDEFB" color="#1565C0"]
        l_eloop    [label="EVENT LOOP\nmain thread context"     shape=box fillcolor="#FFE0B2" color="#E65100"]
        l_critical [label="\xe2\x9a\xa0 CRITICAL PATH\nblocks all I/O"  shape=box fillcolor="#F44336" fontcolor="white" color="#B71C1C" penwidth=4]
        l_external [label="EXTERNAL\namplifier_core"            shape=box fillcolor="#D1C4E9" color="#4527A0"]

        l_block    -> l_offload  [style=invis]
        l_offload  -> l_async    [style=invis]
        l_async    -> l_eloop    [style=invis]
        l_eloop    -> l_critical [style=invis]
        l_critical -> l_external [style=invis]
    }


    // ════════════════════════════════════════════════════════════════════════
    // EDGES: Startup wiring
    // ════════════════════════════════════════════════════════════════════════
    lifespan -> session_manager [label="creates" color="#E65100"]
    lifespan -> bundle_prepare  [label="prewarm\nto_thread \xe2\x9c\x93" color="#388E3C"]
    lifespan -> plugins         [label="discover_plugins"]
    lifespan -> daemon_config   [label="reads config" style=dashed color="#9E9E9E"]
    app -> route_execute        [label="FastAPI\nHTTP dispatch" lhead=cluster_routes color="#1565C0"]


    // ════════════════════════════════════════════════════════════════════════
    // EDGES: Sync execution path
    // ════════════════════════════════════════════════════════════════════════
    route_execute -> session_handle [label="await execute()\n(blocks caller)" color="#E65100"]


    // ════════════════════════════════════════════════════════════════════════
    // EDGES: Streaming path  (PRIMARY CONCERN — thick orange)
    // ════════════════════════════════════════════════════════════════════════
    route_stream -> bg_task       [label="202 returned\nasyncio.create_task(_run())"
                                   color="#E65100" penwidth=2 style=dashed]
    bg_task -> session_handle     [label="await\nSessionHandle.execute(prompt)"
                                   color="#E65100" penwidth=2]


    // ════════════════════════════════════════════════════════════════════════
    // EDGES: SSE subscribe path  (async-safe — blue)
    // ════════════════════════════════════════════════════════════════════════
    route_events -> event_bus  [label="subscribe()\nasync generator" color="#1565C0"]
    event_bus    -> sse_client [label="yield event\nformat as SSE text/event-stream" color="#1565C0"]


    // ════════════════════════════════════════════════════════════════════════
    // EDGES: State layer wiring
    // ════════════════════════════════════════════════════════════════════════
    session_manager -> session_index  [label="register / update\n\xe2\x86\x90 SYNC DISK WRITE"
                                       color="#F44336" penwidth=2]
    session_manager -> session_handle [label="creates / wraps"]
    session_manager -> providers_load [label="load_provider_config()\non create  /  resume\n\xe2\x86\x90 BLOCKING"
                                       color="#F44336" penwidth=2]

    session_handle -> ampl_session    [label="await session.execute()\ndelegates to core"
                                       color="#E65100" penwidth=2]
    session_handle -> event_bus       [label="_on_event() callback\npublish() [sync put_nowait]"
                                       color="#1565C0"]


    // ════════════════════════════════════════════════════════════════════════
    // EDGES: Orchestrator loop  (THE CRITICAL PATH)
    // ════════════════════════════════════════════════════════════════════════
    ampl_session -> orchestrator [label="runs engine loop" color="#E65100"]

    // Async (safe) path — dashed green
    orchestrator -> provider     [label="await provider.complete()\nLLM API call  \xe2\x9c\x93 async"
                                   color="#388E3C" style=dashed]

    // Hook emission path
    orchestrator -> coordinator  [label="hooks.emit(tool:pre)\nhooks.emit(tool:post)\nhooks.emit(orchestrator:complete)"
                                   color="#4527A0"]

    // ── THE BLOCKING CALL — thick red, prominent ──────────────────────────
    orchestrator -> tool_execute [label="tool.execute(args)\nno await \xc2\xb7 no thread"
                                   color="#B71C1C" penwidth=4]

    // Blocking impact annotation — open arrowhead dashed annotation
    tool_execute    -> blocking_impact [label="freezes\nevent loop"
                                        color="#B71C1C" penwidth=2
                                        style=dashed arrowhead=open]

    // Show SSE client is affected
    blocking_impact -> sse_client      [label="no events\ndelivered to client"
                                        color="#C62828" style=dashed arrowhead=open]

    // Coordinator fires back into daemon
    coordinator -> session_handle      [label="fires hook handlers\n\xe2\x86\x92 _on_event() \xe2\x86\x92 EventBus"
                                        color="#4527A0"]


    // ════════════════════════════════════════════════════════════════════════
    // EDGES: Support layer hooks and wiring
    // ════════════════════════════════════════════════════════════════════════
    coordinator -> persistence  [label="hook callbacks\nasyncio.to_thread \xe2\x9c\x93" color="#388E3C"]

    session_handle -> display   [label="_wire_events()\nDisplaySystem hookup" color="#1565C0"]
    display        -> event_bus [label="display event\n\xe2\x86\x92 SSE fanout" color="#1565C0"]

    route_agents -> spawn       [label="spawn child session" color="#E65100"]
    spawn -> session_manager    [label="creates child session"]
    spawn -> event_bus          [label="EventBus tree wiring\nchild events \xe2\x86\x92 parent" color="#1565C0"]

    transport_event -> event_bus [label="wraps events\nas envelope" style=dashed color="#9E9E9E"]

}
